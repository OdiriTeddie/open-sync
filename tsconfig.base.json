{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
    ,
    "baseUrl": ".",
    "paths": {
      "@synckit/shared": ["packages/shared/src/index.ts"],
      "@synckit/core": ["packages/core/src/index.ts"],
      "@synckit/react": ["packages/react/src/index.tsx"]
    }
  }
}
